# ---------------------------------------------------------------
# AVS Invest — Express backend environment template
# Copy this file to `.env` (or set these in your hosting provider's
# environment variables panel — Render, Railway, etc.) before launch.
# ---------------------------------------------------------------

# Port the Express server listens on. Render / Railway override this
# automatically — leave default for local dev.
PORT=5001

# CORS allowlist. Comma-separated list of fully-qualified origins that
# can call this API. In production set this to your real frontend
# domains. The trailing slash should NOT be included.
# Example for production:
#   ALLOWED_ORIGINS=https://avsinvest.co.uk,https://www.avsinvest.co.uk,https://owner.avsinvest.co.uk
# Local dev (defaults if unset): http://localhost:3000, 3001, 3002
ALLOWED_ORIGINS=

# ---------------------------------------------------------------
# Notion integration (AVS portfolio + pipeline)
# Create the integration at https://www.notion.so/profile/integrations
# Then share the AVS property + pipeline databases with the integration.
# ---------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROPERTIES_DB_ID=
NOTION_PIPELINE_DB_ID=

# How many seconds to cache Notion responses before refetching.
# Higher = fewer Notion API calls, lower = fresher data.
NOTION_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------
# MongoDB (planned — not used yet)
# ---------------------------------------------------------------
# MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/avs?retryWrites=true&w=majority

# ---------------------------------------------------------------
# Node env
# ---------------------------------------------------------------
NODE_ENV=development
